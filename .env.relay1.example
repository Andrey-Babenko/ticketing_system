# Prod-style email via relay1 instead of Mailpit (ADR-19, spec §3).
# Copy to .env.relay1 (gitignored), fill in credentials, then:
#   docker compose --env-file .env.relay1 up --build
# Never commit the filled-in .env.relay1 — it holds real credentials.

SMTP_HOST=relay1.dataart.com
SMTP_PORT=465           # confirmed 2026-07-08: relay1 only accepts implicit TLS (465);
                        # 587/STARTTLS times out from the VPN path tested.
SMTP_SECURE=true
SMTP_USER=              # required — relay1 demands AUTH LOGIN (confirmed 2026-07-08,
SMTP_PASS=              # EAUTH "Missing credentials for LOGIN" without it)
SMTP_FROM=you@dataart.com
APP_BASE_URL=http://localhost:8080
