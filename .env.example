# Host-dev values (backend running on host via `npm run dev`,
# db + mailpit via `docker compose up db mailpit`).
# docker-compose.yml has inline defaults — no .env is needed for `docker compose up --build`.
DATABASE_URL=postgresql://app:app@localhost:5432/ticketing
PORT=3000
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@ticketing.local
# Host-dev SPA origin (Vite); the compose default is http://localhost:8080
APP_BASE_URL=http://localhost:5173
# For a real relay (e.g. relay1.dataart.com:587): set SMTP_USER, SMTP_PASS, SMTP_SECURE as required

